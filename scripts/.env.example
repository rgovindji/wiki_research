# Copy this file to ../.env (repo root) and fill in real values.
# .env is gitignored. Never commit secrets.

# =============================================================================
# Anthropic (for ingest.py)
# =============================================================================
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional model override (default: claude-opus-4-7)
# INGEST_MODEL=claude-opus-4-7

# =============================================================================
# Email backend (for daily_email.py) — choose ONE
# =============================================================================
# Pick "ses" (recommended) or "smtp"
EMAIL_BACKEND=ses

# Default recipient (overridable with --to)
EMAIL_TO=rgovindji@gmail.com

# ----- AWS SES backend -----
# AWS credentials come from the default boto3 chain (~/.aws/credentials, env
# vars, IAM role on EC2/Lambda, etc.) — no explicit creds here.
# The SENDER must be a verified SES identity. Verify a new one with:
#   aws sesv2 create-email-identity --email-identity wiki@example.com
#   (then click the verification link from AWS)
# Existing verified identities in your account (as of setup):
#   - decideai.xyz (domain — any address @decideai.xyz works)
#   - modclub.app  (domain — any address @modclub.app works)
#   - sagarshah16@gmail.com (specific email)
#   - tareq@decideai.xyz (specific email)
SES_SENDER=wiki@decideai.xyz
AWS_REGION=us-east-1

# ----- Gmail SMTP backend -----
# Only needed if EMAIL_BACKEND=smtp
# 1. Enable 2-Step Verification on the Google account
# 2. Create an App Password at https://myaccount.google.com/apppasswords
# 3. Paste the 16-char app password below (NOT your regular Gmail password)
# GMAIL_USER=youraddress@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
